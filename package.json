{
  "name": "demo-npm-semver",
  "version": "1.0.6",
  "description": "Demo npm repository for semantic versioning with GitHub Actions",
  "main": "src/index.js",
  "scripts": {
    "build": "node -e \"const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.copyFileSync('src/index.js','dist/index.js'); console.log('Build completed');\"",
    "test": "node test/version.test.js",
    "version:validate": "bash scripts/validate-feature-version.sh",
    "version:snapshot": "bash scripts/bump-snapshot-version.sh",
    "version:release": "bash scripts/strip-snapshot-version.sh"
  },
  "keywords": [
    "npm",
    "semver",
    "github-actions",
    "snapshot-versioning"
  ],
  "license": "MIT"
}
